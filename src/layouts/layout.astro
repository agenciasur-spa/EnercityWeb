---
import '../styles/global.css';
import { getBusinessInfo } from '../lib/content';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const {
  title,
  description = "Simula tu ahorro con paneles solares. Cotización personalizada en minutos para tu hogar o empresa en Chile.",
  ogTitle,
  ogDescription,
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const siteName = "Enercity";
const siteUrl = "https://paneles-solares.cl";

const businessInfo = await getBusinessInfo();

// OG tags: use dynamic values if provided, otherwise derive from page props
const resolvedOgTitle = ogTitle || `${title} — ${siteName}`;
const resolvedOgDescription = ogDescription || description;

// JSON-LD Structured Data
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}#organization`,
      name: businessInfo.razonSocial,
      legalName: businessInfo.nombreLegal,
      alternateName: siteName,
      url: siteUrl,
      logo: `${siteUrl}/logo.png`,
      image: `${siteUrl}/logo.png`,
      description: description,
      telephone: businessInfo.telefono,
      email: businessInfo.email,
      address: {
        "@type": "PostalAddress",
        streetAddress: "Av. Pedro de Valdivia 273, oficina 1611",
        addressLocality: "Providencia",
        addressRegion: "Región Metropolitana",
        addressCountry: "CL"
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: -33.4389,
        longitude: -70.6506
      },
      areaServed: {
        "@type": "Place",
        name: businessInfo.cobertura
      },
      openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "08:30",
        closes: "18:30",
        timeZone: businessInfo.horarioZona
      },
      priceRange: "$$",
      sameAs: []
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}#org`,
      name: siteName,
      url: siteUrl,
      logo: `${siteUrl}/logo.png`,
      description: description,
      contactPoint: {
        "@type": "ContactPoint",
        telephone: businessInfo.telefono,
        email: businessInfo.email,
        contactType: "customer service",
        availableLanguage: ["Spanish", "English"]
      },
      areaServed: {
        "@type": "Country",
        name: "Chile"
      },
      knowsAbout: businessInfo.servicios
    },
    {
      "@type": "Service",
      "@id": `${siteUrl}#service`,
      name: "Instalación de paneles solares",
      description: businessInfo.servicios.join(". "),
      provider: {
        "@type": "Organization",
        name: businessInfo.razonSocial
      },
      areaServed: {
        "@type": "Place",
        name: businessInfo.cobertura
      },
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Servicios fotovoltaicos",
        itemListElement: businessInfo.servicios.map((service, index) => ({
          "@type": "Offer",
          position: index + 1,
          name: service
        }))
      }
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      url: siteUrl,
      name: siteName,
      description: description,
      publisher: {
        "@type": "Organization",
        name: businessInfo.razonSocial
      }
    }
  ]
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700;900&display=swap" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteName} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_CL" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    <slot />
  </body>
</html>
