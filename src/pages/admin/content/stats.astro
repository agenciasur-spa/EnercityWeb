---
import AdminLayout from '@/layouts/admin-layout.astro';
import StatsTable from '@/components/admin/content/stats-table';
import { supabaseAdmin } from '@/lib/supabase-admin';

export const prerender = false;

const { data, error } = await supabaseAdmin
  .from('stats')
  .select('*')
  .order('sort_order', { ascending: true });

if (error) {
  console.error('[stats.astro] Supabase query error:', error);
}

const stats = data ?? [];
---

<AdminLayout title="Estadísticas — Enercity Admin">
  <StatsTable client:load stats={stats} />
</AdminLayout>
