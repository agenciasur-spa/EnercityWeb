---
import AdminLayout from '@/layouts/admin-layout.astro';
import SectionsEditor from '@/components/admin/content/sections-editor';
import { supabaseAdmin } from '@/lib/supabase-admin';

export const prerender = false;

const { data, error } = await supabaseAdmin
  .from('site_content')
  .select('*')
  .order('section', { ascending: true });

if (error) {
  console.error('[sections.astro] Supabase query error:', error);
}

type SiteContentRow = {
  id: string;
  section: string;
  data: Record<string, unknown>;
  updated_at: string;
};

const sections = (data ?? []) as unknown as SiteContentRow[];
---

<AdminLayout title="Secciones — Enercity Admin">
  <SectionsEditor client:load sections={sections} />
</AdminLayout>
